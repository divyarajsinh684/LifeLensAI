APP_NAME=LifeLens AI
ENV=development
PORT=8000
HOST=0.0.0.0

# CHANGE THIS in production — use any random 64-char string
SECRET_KEY=lifelens-secret-key-change-this-in-production-use-random-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SQLite — works out of the box, no setup needed
DATABASE_URL=sqlite+aiosqlite:///./lifelens.db

# PostgreSQL for production (uncomment and fill):
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/lifelens_db

ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
